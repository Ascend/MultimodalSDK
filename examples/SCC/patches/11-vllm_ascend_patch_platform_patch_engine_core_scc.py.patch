+#
+# Patch Qwen2.5-VL in vLLM to apply SCC vision-token compression and re-apply
+# it in the spawned EngineCore process.
+# Strategy (Path A -- geometric K_target, no extra ViT run):
+#   1. Wrap Qwen2VLProcessingInfo.get_num_image_tokens / get_num_video_tokens
+#      so that the placeholder count becomes ceil(N * ratio) instead of N.
+#   2. Wrap Qwen2_5_VLForConditionalGeneration._process_image_input and
+#      _process_video_input so that AFTER the vision tower runs, the flat
+#      [N_i, D] embedding for each item is SCC-compressed down to exactly
+#      K_i_target = ceil(N_i * ratio). Token count then matches the
+#      placeholder count from step 1.
+#
+# Why monkey-patch instead of ModelRegistry.register_model?
+#   ModelRegistry.register_model would replace the model class, but the
+#   placeholder-count decision is made inside the ProcessingInfo, which is
+#   wired to the class via @MULTIMODAL_REGISTRY.register_processor. Patching
+#   the two methods we need is simpler, survives vLLM minor-version changes
+#   better, and matches vllm-ascend's existing style (see patch_huanyuan_vl.py
+#   and patch_multimodal_merge.py).
+
+import math
+from collections.abc import Callable
+
+import numpy as np
+import torch
+from loguru import logger
+
+import vllm_ascend.envs as envs_ascend
+
+_orig_run_engine_core = None
+
+
+def _scc_shrink(n: int, ratio: float) -> int:
+    """Return the fixed placeholder/feature target length used by SCC."""
+    return max(1, math.ceil(n * ratio))
+
+
+def _scc_should_compress(n: int, max_tokens_per_item: int) -> bool:
+    """Whether a single image/video item should go through SCC."""
+    return max_tokens_per_item <= 0 or n <= max_tokens_per_item
+
+
+def _sample_mrope_positions(grid_indices: np.ndarray,
+                            target_len: int) -> np.ndarray:
+    """Return exactly target_len media positions from a full mROPE grid."""
+    flat = grid_indices.reshape(3, -1)
+    orig_len = flat.shape[1]
+    if target_len == orig_len:
+        return flat
+    if target_len <= 0:
+        return flat[:, :0]
+    if target_len < orig_len:
+        keep = np.linspace(0, orig_len - 1, target_len, dtype=np.int64)
+        return flat[:, keep]
+    pad = np.broadcast_to(flat[:, -1:], (3, target_len - orig_len))
+    return np.concatenate([flat, pad], axis=1)
+
+
+def apply_qwen25vl_scc_patch():
+    ratio = envs_ascend.VLLM_ASCEND_SCC_RATIO
+    tau = envs_ascend.VLLM_ASCEND_SCC_TAU
+    epsilon = envs_ascend.VLLM_ASCEND_SCC_EPSILON
+    max_tokens_per_item = envs_ascend.VLLM_ASCEND_SCC_MAX_TOKENS_PER_ITEM
+
+    if not (0.0 < ratio <= 1.0):
+        logger.warning(
+            f"[SCC] VLLM_ASCEND_SCC_RATIO={ratio} out of (0, 1], disabling SCC."
+        )
+        return
+    if not (0.0 < tau <= 1.0):
+        logger.warning(
+            f"[SCC] VLLM_ASCEND_SCC_TAU={tau} out of (0, 1], disabling SCC."
+        )
+        return
+
+    # Imports deferred so that the module still loads on stacks where vLLM's
+    # qwen2_5_vl (or its qwen2_vl ancestor) isn't importable for some reason.
+    try:
+        from vllm.model_executor.models import qwen2_5_vl as q25
+        from vllm.model_executor.models import qwen2_vl as q2
+    except ImportError as e:
+        logger.warning(f"[SCC] Could not import Qwen2/2.5-VL modules: {e}. "
+                       "SCC patch not applied.")
+        return
+
+    from vllm_ascend.ops.scc_compressor import scc_compress_to_target
+
+    # ------------------------------------------------------------------
+    # (1) Patch ProcessingInfo: shrink the placeholder count.
+    # ------------------------------------------------------------------
+    # Qwen2.5-VL inherits its token-count logic from Qwen2VLProcessingInfo
+    # (vllm/model_executor/models/qwen2_vl.py).  The chain is:
+    #   _get_vision_info -> returns (resized_h, resized_w, num_tokens)
+    #   get_num_image_tokens(image_width, image_height) -> int
+    #   get_num_video_tokens(image_width, image_height, num_frames, ...) -> int
+    # All three call into _get_vision_info. The cleanest patch point is to
+    # wrap get_num_image_tokens and get_num_video_tokens and shrink the
+    # result.  _get_prompt_updates and the mm kwargs placeholder expansion
+    # both honor these counts.
+    ProcessingInfo = q2.Qwen2VLProcessingInfo
+
+    if getattr(ProcessingInfo, "_scc_patched", False):
+        return  # idempotent
+
+    _orig_get_num_image_tokens = ProcessingInfo.get_num_image_tokens
+    _orig_get_num_video_tokens = ProcessingInfo.get_num_video_tokens
+
+    def _shrink(n: int) -> int:
+        return _scc_shrink(n, ratio)
+
+    def _should_compress(n: int) -> bool:
+        return _scc_should_compress(n, max_tokens_per_item)
+
+    def _scc_get_num_image_tokens(self, *args, **kwargs):
+        n = _orig_get_num_image_tokens(self, *args, **kwargs)
+        if not _should_compress(n):
+            return n
+        k = _shrink(n)
+        logger.debug(f"[SCC] shrink placeholders (image): N={n} -> K={k}")
+        return k
+
+    def _scc_get_num_video_tokens(self, *args, **kwargs):
+        n = _orig_get_num_video_tokens(self, *args, **kwargs)
+        if not _should_compress(n):
+            return n
+        k = _shrink(n)
+        logger.debug(f"[SCC] shrink placeholders (video): N={n} -> K={k}")
+        return k
+
+    ProcessingInfo.get_num_image_tokens = _scc_get_num_image_tokens
+    ProcessingInfo.get_num_video_tokens = _scc_get_num_video_tokens
+
+    # vLLM 0.17's Qwen2.5-VL prompt replacement path does not necessarily call
+    # get_num_image_tokens/get_num_video_tokens; it can derive the placeholder
+    # count directly from grid_thw in _get_prompt_updates.  Wrap the generated
+    # replacement callbacks as well so real OpenAI requests get the same K.
+    def _truncate_prompt_content(content, k_target: int):
+        if isinstance(content, (list, tuple)):
+            return content[:k_target]
+        return content
+
+    def _wrap_replacement(replacement, modality: str):
+        if not isinstance(replacement, Callable):
+            if not hasattr(replacement, "__len__"):
+                return replacement
+            n = len(replacement)
+            if not _should_compress(n):
+                return replacement
+            return _truncate_prompt_content(replacement, _shrink(n))
+
+        def _scc_replacement(item_idx: int):
+            content = replacement(item_idx)
+            if not hasattr(content, "__len__"):
+                return content
+            n = len(content)
+            if not _should_compress(n):
+                logger.debug(
+                    f"[SCC] skip prompt placeholder shrink "
+                    f"({modality}[{item_idx}]): N={n} exceeds "
+                    f"max_tokens_per_item={max_tokens_per_item}"
+                )
+                return content
+            k = _shrink(n)
+            logger.debug(
+                f"[SCC] shrink prompt placeholders ({modality}[{item_idx}]): "
+                f"N={n} -> K={k}"
+            )
+            return _truncate_prompt_content(content, k)
+
+        return _scc_replacement
+
+    def _patch_prompt_updates(cls):
+        if cls is None or cls.__dict__.get("_scc_prompt_updates_patched", False):
+            return
+        orig_get_prompt_updates = getattr(cls, "_get_prompt_updates", None)
+        if orig_get_prompt_updates is None:
+            return
+
+        def _scc_get_prompt_updates(self, *args, **kwargs):
+            updates = orig_get_prompt_updates(self, *args, **kwargs)
+            for update in updates:
+                modality = getattr(update, "modality", "")
+                if modality not in ("image", "video"):
+                    continue
+                replacement = getattr(update, "replacement", None)
+                if replacement is None:
+                    continue
+                update.replacement = _wrap_replacement(replacement, modality)
+            return updates
+
+        cls._get_prompt_updates = _scc_get_prompt_updates
+        cls._scc_prompt_updates_patched = True
+
+    _patch_prompt_updates(getattr(q2, "Qwen2VLMultiModalProcessor", None))
+    _patch_prompt_updates(getattr(q25, "Qwen2_5_VLMultiModalProcessor", None))
+
+    # ------------------------------------------------------------------
+    # (2) Patch the model's _process_image_input / _process_video_input.
+    # ------------------------------------------------------------------
+    # Upstream signatures (vllm 0.17):
+    #   _process_image_input(self, image_input) -> tuple[torch.Tensor, ...]
+    #   _process_video_input(self, video_input) -> tuple[torch.Tensor, ...]
+    # Each returns a tuple of per-item tensors, one per image/video, split
+    # by grid_thw.prod() // merge_size**2.  We compress each per-item tensor
+    # to its ratio-shrunken target length.
+    ModelCls = q25.Qwen2_5_VLForConditionalGeneration
+
+    _orig_process_image = ModelCls._process_image_input
+    _orig_process_video = ModelCls._process_video_input
+    _orig_get_mrope_input_positions = getattr(
+        ModelCls, "get_mrope_input_positions", None
+    )
+
+    # merge_size is identical for images and videos for Qwen2.5-VL. Read it
+    # from the vision config once; falls back to 2 (Qwen2.5-VL default).
+    def _get_merge_size(model):
+        try:
+            return int(model.visual.spatial_merge_size)
+        except AttributeError as exc:
+            logger.debug(
+                f"[SCC] model.visual.spatial_merge_size is unavailable: {exc}; "
+                "fallback to default merge_size=2."
+            )
+            return 2
+
+    def _compress_video_item(feat: torch.Tensor,
+                             grid_thw: torch.Tensor,
+                             merge_size: int,
+                             k_target: int) -> torch.Tensor:
+        """feat: [N_i, D]. Use grid_thw to derive frame layout for video SCC."""
+        # grid_thw: [3] -> (t, h, w) BEFORE merge_size collapsing.
+        t, h, w = (int(x) for x in grid_thw.tolist())
+        tokens_per_frame = (h * w) // (merge_size * merge_size)
+        num_frames = t
+        # Defensive check: tokens_per_frame*num_frames should == N_i.
+        if tokens_per_frame * num_frames != feat.shape[0]:
+            # Structure unexpectedly mismatched; fall back to image SCC.
+            logger.debug(
+                f"[SCC] video grid mismatch: tokens_per_frame="
+                f"{tokens_per_frame}, num_frames={num_frames}, "
+                f"feat_tokens={feat.shape[0]}; fallback to image-style "
+                "SCC compression."
+            )
+            return scc_compress_to_target(
+                feat, k_target=k_target, num_frames=1, tokens_per_frame=0,
+                tau=tau, epsilon=epsilon,
+            )
+        return scc_compress_to_target(
+            feat,
+            k_target=k_target,
+            num_frames=num_frames,
+            tokens_per_frame=tokens_per_frame,
+            tau=tau,
+            epsilon=epsilon,
+        )
+
+    def _compress_image_item(feat: torch.Tensor,
+                             k_target: int) -> torch.Tensor:
+        return scc_compress_to_target(
+            feat, k_target=k_target, num_frames=1, tokens_per_frame=0,
+            tau=tau, epsilon=epsilon,
+        )
+
+    def _get_grid_thw(mm_input, key: str):
+        """Safely extract grid_thw (dict-get, attr, or None)."""
+        try:
+            return mm_input.get(key)  # TypedDict / dict behaves like this.
+        except AttributeError:
+            return getattr(mm_input, key, None)
+
+    def _scc_get_mrope_input_positions(self, input_tokens, mm_features):
+        if _orig_get_mrope_input_positions is None:
+            raise AttributeError("get_mrope_input_positions is unavailable")
+
+        llm_pos_ids_list = []
+        st = 0
+        spatial_merge_size = self.config.vision_config.spatial_merge_size
+        tokens_per_second = getattr(
+            self.config.vision_config, "tokens_per_second", 1.0
+        )
+
+        for mm_feature in sorted(mm_features, key=lambda f: f.mm_position.offset):
+            offset = mm_feature.mm_position.offset
+            text_len = offset - st
+            if text_len < 0:
+                raise ValueError(
+                    "[SCC] mROPE offset moved backwards after compression: "
+                    f"offset={offset}, st={st}, modality={mm_feature.modality}, "
+                    f"placeholder_len={mm_feature.mm_position.length}"
+                )
+
+            st_idx = llm_pos_ids_list[-1].max() + 1 if llm_pos_ids_list else 0
+            llm_pos_ids_list.append(
+                np.broadcast_to(np.arange(text_len), (3, text_len)) + st_idx
+            )
+
+            if mm_feature.modality == "image":
+                t, h, w = mm_feature.data["image_grid_thw"].data.tolist()
+                if int(t) != 1:
+                    raise ValueError(f"Image must have 1 frame, got {t}")
+                llm_grid_t = 1
+                llm_grid_h = h // spatial_merge_size
+                llm_grid_w = w // spatial_merge_size
+                t_factor = 1.0
+            elif mm_feature.modality == "video":
+                t, h, w = mm_feature.data["video_grid_thw"].data.tolist()
+                second_per_grid_ts = 1.0
+                if mm_feature.data.get("second_per_grid_ts", None):
+                    second_per_grid_ts = mm_feature.data[
+                        "second_per_grid_ts"
+                    ].data.item()
+                llm_grid_t = t
+                llm_grid_h = h // spatial_merge_size
+                llm_grid_w = w // spatial_merge_size
+                t_factor = second_per_grid_ts * tokens_per_second
+            else:
+                raise ValueError(f"Unsupported modality: {mm_feature.modality}")
+
+            grid_indices = np.indices((llm_grid_t, llm_grid_h, llm_grid_w))
+            if t_factor != 1.0:
+                grid_indices[0] = (grid_indices[0] * t_factor).astype(np.int64)
+
+            media_len = int(mm_feature.mm_position.length)
+            media_positions = _sample_mrope_positions(grid_indices, media_len)
+            llm_pos_ids_list.append(media_positions + text_len + st_idx)
+            st = offset + media_len
+
+        if st < len(input_tokens):
+            st_idx = llm_pos_ids_list[-1].max() + 1 if llm_pos_ids_list else 0
+            text_len = len(input_tokens) - st
+            llm_pos_ids_list.append(
+                np.broadcast_to(np.arange(text_len), (3, text_len)) + st_idx
+            )
+
+        llm_positions = np.concatenate(llm_pos_ids_list, axis=1).reshape(3, -1)
+        mrope_position_delta = (llm_positions.max() + 1 - len(input_tokens)).item()
+        return torch.from_numpy(llm_positions), mrope_position_delta
+
+    def _scc_process_image_input(self, image_input):
+        feats = _orig_process_image(self, image_input)
+        grid_thw = _get_grid_thw(image_input, "image_grid_thw")
+        merge_size = _get_merge_size(self)
+        out = []
+        for i, feat in enumerate(feats):
+            N_i = feat.shape[0]
+            k_target = _shrink(N_i)
+            if not _should_compress(N_i):
+                logger.debug(
+                    f"[SCC] skip ViT compression (image[{i}]): N={N_i} "
+                    f"exceeds max_tokens_per_item={max_tokens_per_item}"
+                )
+                out.append(feat)
+                continue
+            if k_target >= N_i:
+                out.append(feat)
+                continue
+            logger.debug(
+                f"[SCC] compress ViT out (image[{i}]): "
+                f"N={N_i} -> K={k_target}"
+            )
+            if grid_thw is not None:
+                gt = grid_thw[i]
+                t = int(gt[0].item()) if gt.dim() > 0 else int(gt.item())
+                if t > 1:
+                    out.append(_compress_video_item(feat, gt, merge_size,
+                                                   k_target))
+                    continue
+            out.append(_compress_image_item(feat, k_target))
+        return tuple(out)
+
+    def _scc_process_video_input(self, video_input):
+        feats = _orig_process_video(self, video_input)
+        grid_thw = _get_grid_thw(video_input, "video_grid_thw")
+        merge_size = _get_merge_size(self)
+        out = []
+        for i, feat in enumerate(feats):
+            N_i = feat.shape[0]
+            k_target = _shrink(N_i)
+            if not _should_compress(N_i):
+                logger.debug(
+                    f"[SCC] skip ViT compression (video[{i}]): N={N_i} "
+                    f"exceeds max_tokens_per_item={max_tokens_per_item}"
+                )
+                out.append(feat)
+                continue
+            if k_target >= N_i:
+                out.append(feat)
+                continue
+            logger.debug(
+                f"[SCC] compress ViT out (video[{i}]): "
+                f"N={N_i} -> K={k_target}"
+            )
+            if grid_thw is not None:
+                out.append(_compress_video_item(feat, grid_thw[i], merge_size,
+                                               k_target))
+            else:
+                logger.debug(
+                    f"[SCC] video_grid_thw missing for video[{i}], "
+                    "fallback to image-style SCC compression."
+                )
+                out.append(_compress_image_item(feat, k_target))
+        return tuple(out)
+
+    ModelCls._process_image_input = _scc_process_image_input
+    ModelCls._process_video_input = _scc_process_video_input
+    if _orig_get_mrope_input_positions is not None:
+        ModelCls.get_mrope_input_positions = _scc_get_mrope_input_positions
+
+    ProcessingInfo._scc_patched = True
+    logger.info(
+        f"[SCC] Qwen2.5-VL vision-token compression ENABLED "
+        f"(ratio={ratio}, tau={tau}, epsilon={epsilon}, "
+        f"max_tokens_per_item={max_tokens_per_item})."
+    )
+
+
+def _scc_run_engine_core(*args, **kwargs):
+    """Wrap run_engine_core to re-apply SCC patch in EngineCore subprocess."""
+    apply_qwen25vl_scc_patch()
+    return _orig_run_engine_core(*args, **kwargs)
+
+
+def patch_engine_core_for_scc():
+    """Install the EngineCore subprocess re-patch hook when vLLM v1 is present."""
+    global _orig_run_engine_core
+    try:
+        from vllm.v1.engine.core import EngineCoreProc
+    except ImportError as e:
+        logger.warning(f"[SCC] Could not import EngineCoreProc: {e}. "
+                       "EngineCore subprocess re-patch not applied.")
+        return
+
+    if getattr(EngineCoreProc, "_scc_engine_core_patched", False):
+        return
+
+    _orig_run_engine_core = EngineCoreProc.run_engine_core
+    EngineCoreProc.run_engine_core = _scc_run_engine_core
+    EngineCoreProc._scc_engine_core_patched = True
+
+
+if envs_ascend.VLLM_ASCEND_ENABLE_SCC:
+    apply_qwen25vl_scc_patch()
+    patch_engine_core_for_scc()
