+import numpy as np
+
+from tests.ut.base import TestBase
+from vllm_ascend.patch.platform.patch_engine_core_scc import (
+    _sample_mrope_positions,
+    _scc_shrink,
+    _scc_should_compress,
+)
+
+
+class TestPatchEngineCoreScc(TestBase):
+
+    def test_scc_shrink_keeps_at_least_one_token(self):
+        self.assertEqual(_scc_shrink(10, 0.3), 3)
+        self.assertEqual(_scc_shrink(1, 0.01), 1)
+
+    def test_scc_should_compress_respects_max_tokens_per_item(self):
+        self.assertTrue(_scc_should_compress(8192, 8192))
+        self.assertFalse(_scc_should_compress(8193, 8192))
+        self.assertTrue(_scc_should_compress(8193, 0))
+
+    def test_sample_mrope_positions_downsamples_and_pads_to_target_length(self):
+        grid = np.indices((1, 2, 4))
+
+        sampled = _sample_mrope_positions(grid, 3)
+        self.assertEqual(sampled.shape, (3, 3))
+        self.assertEqual(sampled[:, 0].tolist(), [0, 0, 0])
+        self.assertEqual(sampled[:, -1].tolist(), [0, 1, 3])
+
+        padded = _sample_mrope_positions(grid, 10)
+        self.assertEqual(padded.shape, (3, 10))
+        self.assertEqual(padded[:, -1].tolist(), [0, 1, 3])
